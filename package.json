{
  "name": "claude-memory-mcp",
  "version": "2.4.3",
  "description": "MCP memory server for Claude Code — persistent, searchable codebase knowledge",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "setup": "./setup.sh",
    "release": "release-it"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.10.0",
    "onnxruntime-node": "^1.26.0",
    "vectra": "^0.15.0"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^11.0.1",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "release-it": "^20.2.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
